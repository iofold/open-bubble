# Optional: let the top-level ngrok launcher authenticate without a global ngrok config.
NGROK_AUTHTOKEN=

# Required for the screenshot + prompt classifier in apps/api.
OPENAI_API_KEY=

# Optional: override the default OpenAI model used for request classification.
# Defaults to gpt-5.4.
OPEN_BUBBLE_CLASSIFIER_MODEL=

# Optional: override the OpenAI-compatible Responses API base URL used by the backend classifier.
OPEN_BUBBLE_CLASSIFIER_BASE_URL=

# Managed by ./scripts/start-api-ngrok.sh
OPEN_BUBBLE_API_BASE_URL=

# Optional: enables API-owned Composio Tool Router MCP sessions.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=open-bubble-local

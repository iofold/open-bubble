{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-bubble.local/schemas/mcp-fetch-result.schema.json",
  "title": "Open Bubble MCP Fetch Result",
  "type": "object",
  "required": ["sessionId", "connector", "operation", "results"],
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "connector": {
      "type": "string",
      "enum": ["gmail", "drive", "calendar"]
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string"
    },
    "fetchedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRequestId": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

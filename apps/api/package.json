{
  "name": "@open-bubble/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Fastify API MVP for Codex Bubble",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:ngrok": "tsx src/dev/start-api-ngrok.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@open-bubble/codex-app-server": "file:../codex-app-server",
    "fastify": "^5.6.1",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
